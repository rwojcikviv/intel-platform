# intel-platform environment variables
# Copy this file to .env on the LXC and fill in actual values.
# NEVER commit .env to git.

# --- MariaDB on Zenbox (target database) ---
DB_HOST=s49.zenbox.pl
DB_PORT=3306
DB_USER=vivcom_admin1
DB_PASSWORD=<wpisz_haslo>
DB_NAME=vivcom_intel
DB_SSL_DISABLED=1                # Zenbox MariaDB 10.6 nie wymaga SSL dla remote

# --- Jitbit MSSQL (source for initial import) ---
JITBIT_HOST=<host_mssql>
JITBIT_PORT=1433
JITBIT_USER=<user_mssql>
JITBIT_PASSWORD=<haslo_mssql>
JITBIT_DATABASE=<nazwa_bazy>
JITBIT_DRIVER=ODBC Driver 18 for SQL Server

# --- Polish business registers (Faza 3, na razie niewymagane) ---
# Biała Lista VAT — bez klucza, publiczne API
BIALA_LISTA_API_URL=https://wl-api.mf.gov.pl

# GUS REGON API — wymaga klucza (rejestracja: https://api.stat.gov.pl)
GUS_REGON_API_KEY=<klucz_gus>
GUS_REGON_API_URL=https://wyszukiwarkaregon.stat.gov.pl/wsBIR/UslugaBIRzewnPubl.svc

# CEIDG — bez klucza, publiczne
CEIDG_API_URL=https://datastore.ceidg.gov.pl/api

# KRS — bez klucza, publiczne
KRS_API_URL=https://api-krs.ms.gov.pl

# --- External APIs (Faza 4+, monitoring) ---
# Anthropic API (analyzer)
ANTHROPIC_API_KEY=<klucz_anthropic>

# Apify (FB/IG scraping, opcjonalnie)
APIFY_TOKEN=<token_apify>

# Google Maps Places API (opcjonalnie, do walidacji adresów)
GOOGLE_MAPS_API_KEY=<klucz_gmaps>

# --- Storage paths (na LXC) ---
SNAPSHOTS_DIR=/opt/intel-platform/data/snapshots
LOGS_DIR=/opt/intel-platform/logs
